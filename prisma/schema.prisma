datasource db {
  provider  = "postgresql"
}



generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  role          String         @default("RESEARCHER") // ADMIN, RESEARCHER, STUDENT, INSTITUTION
  photoUrl      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  researcher    Researcher?
  notifications Notification[]

  @@map("users")
}

model Researcher {
  id                 String          @id @default(uuid())
  userId             String?         @unique
  user               User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchId         String          @unique // e.g. HX-RES-2026-0001
  fullName           String
  photoUrl           String?
  bio                String?
  institutionName    String?
  researchInterests  String          @default("[]") // JSON string list
  skills             String          @default("[]") // JSON string list
  linkedIn           String?
  isVerified         Boolean         @default(false)
  researchScore      Float           @default(0.0)
  publicationCount   Int             @default(0)
  projectCount       Int             @default(0)
  slug               String          @unique // slug for profile URL (e.g. avnish-verma)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  publications       Publication[]
  projectsJoined     ProjectMember[]
  projectsCreated    Project[]

  @@map("researchers")
}

model Publication {
  id           String     @id @default(uuid())
  title        String
  abstract     String
  keywords     String     @default("[]") // JSON string list
  authors      String     @default("[]") // JSON string list
  category     String     @default("WHITE_PAPER") // WHITE_PAPER, RESEARCH_ARTICLE, LITERATURE_REVIEW
  pdfUrl       String?
  fileKey      String?
  isApproved   Boolean    @default(false)
  researcherId String
  researcher   Researcher @relation(fields: [researcherId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("publications")
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  category    String          @default("Biomedical")
  timeline    String?         // e.g. "Jun 2026 - Dec 2026"
  progress    Int             @default(0) // progress percentage 0-100
  creatorId   String
  creator     Researcher      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("projects")
}

model ProjectMember {
  id           String     @id @default(uuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  researcherId String
  researcher   Researcher @relation(fields: [researcherId], references: [id], onDelete: Cascade)
  role         String     @default("COLLABORATOR") // OWNER, COLLABORATOR
  joinedAt     DateTime   @default(now())

  @@unique([projectId, researcherId])
  @@map("project_members")
}

model FellowshipApplication {
  id                 String   @id @default(uuid())
  fullName           String
  institutionName    String
  course             String
  researchInterests  String   @default("[]") // JSON string list
  cvUrl              String?
  statementOfPurpose String
  status             String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("fellowship_applications")
}

model Institution {
  id          String   @id @default(uuid())
  name        String   @unique
  location    String
  logoUrl     String?
  description String?
  website     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("institutions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  body      String
  status    String   @default("LOGGED") // SENT, FAILED, LOGGED
  sentAt    DateTime @default(now())

  @@map("email_logs")
}

model TrainingProgress {
  id           String    @id @default(uuid())
  userId       String
  moduleIndex  Int       // 0, 1, 2, 3
  isCompleted  Boolean   @default(false)
  quizScore    Int?      // percentage score e.g. 100
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([userId, moduleIndex])
  @@map("training_progress")
}

model Certificate {
  id           String    @id @default(uuid())
  userId       String    @unique
  fullName     String    // Name printed on certificate
  certHash     String    @unique // Verifiable hash
  issuedAt     DateTime  @default(now())

  @@map("certificates")
}

model AmbassadorApplication {
  id            String   @id @default(uuid())
  fullName      String
  email         String
  collegeName   String
  degreeProgram String?
  yearOfStudy   String?
  linkedin      String?
  sop           String   // Statement of purpose / motivation
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ambassador_applications")
}
